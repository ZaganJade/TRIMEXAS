APP_NAME=Trimexas
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — PostgreSQL 17 (via docker-compose service `postgres`)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=trimexas
DB_USERNAME=trimexas
DB_PASSWORD=trimexas
# Host port for direct DB access from your machine
DB_PORT_HOST=5432

# Sessions / Cache / Queue all on database driver — zero extra infra
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Redis (optional; not used by default)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Mailpit (dev). Demo: switch MAIL_HOST/USER/PASSWORD to Gmail SMTP.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@trimexas.local"
MAIL_FROM_NAME="${APP_NAME}"

# Docker-compose host ports (override if conflict)
APP_PORT=8080
MAIL_UI_PORT=8025
MAIL_SMTP_PORT=1025
VITE_PORT=5173

VITE_APP_NAME="${APP_NAME}"
