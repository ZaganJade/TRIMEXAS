{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint . --ext .js,.vue",
        "lint:fix": "eslint . --ext .js,.vue --fix",
        "format": "prettier --write \"resources/**/*.{js,vue,css}\"",
        "format:check": "prettier --check \"resources/**/*.{js,vue,css}\"",
        "prepare": "husky || true"
    },
    "lint-staged": {
        "*.{js,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{css,json,md}": [
            "prettier --write"
        ],
        "*.php": [
            "vendor/bin/pint --quiet"
        ]
    },
    "devDependencies": {
        "@prettier/plugin-php": "^0.25.0",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^22.13.5",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vueuse/core": "^12.8.2",
        "concurrently": "^9.0.1",
        "eslint": "^10.4.0",
        "eslint-plugin-vue": "^10.9.1",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^3.1.0",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^5.6.0",
        "vite": "^8.0.0",
        "vue-tsc": "^2.2.4"
    },
    "dependencies": {
        "@inertiajs/vue3": "^2.3.24",
        "@lucide/vue": "^1.16.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lenis": "^1.3.23",
        "motion-v": "^2.2.1",
        "radix-vue": "^1.9.17",
        "tailwind-merge": "^2.6.1",
        "vue": "^3.5.34",
        "vue-sonner": "^2.0.9",
        "ziggy-js": "^2.6.2"
    }
}
